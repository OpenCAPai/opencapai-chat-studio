# OpenCAP AI Chat Studio - Environment Variables

# Encryption key for sensitive data (REQUIRED for production)
# Generate a secure key with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-key-here

# AI Core Configuration (optional, can be configured via UI)
AICORE_ENDPOINT=
AICORE_RESOURCE_GROUP=default
AICORE_TOKEN=
AICORE_DEPLOYMENT_URL=