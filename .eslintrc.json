{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true,
    "browser": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "sap": "readonly",
    "SELECT": "readonly",
    "INSERT": "readonly",
    "UPDATE": "readonly",
    "DELETE": "readonly",
    "cds": "readonly"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["srv/**/*.js", "db/**/*.js", "tests/**/*.js"],
      "parserOptions": {
        "sourceType": "commonjs"
      }
    }
  ]
}
